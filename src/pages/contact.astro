---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Get in Touch";
const pageDescription =
  "Have a question or need help? Generate an email draft and send it to us directly.";
---

<script>
  const contactEmail = "hello@operately.com";

  const subjectByHelpType: Record<string, string> = {
    access: "Account access help",
    "pre-signup": "Question before signing up",
    "user-question": "Question from an Operately user",
    bug: "Bug report",
    feature: "Feature request",
    "ai-access": "Operately AI early access",
    "commercial-license": "Commercial self-hosted license",
    other: "Question for Operately",
  };

  function initContactForm() {
    const form = document.getElementById("contact-form") as HTMLFormElement;
    if (!form) return;

    // Check for URL parameters to pre-select options
    const urlParams = new URLSearchParams(window.location.search);
    const helpType = urlParams.get("help-type");
    if (helpType) {
      const select = form.querySelector(
        'select[name="help-type"]'
      ) as HTMLSelectElement;
      if (select) {
        select.value = helpType;
      }
    }

    const helpTypeSelect = form.querySelector(
      'select[name="help-type"]'
    ) as HTMLSelectElement;
    const messageInput = form.querySelector(
      'textarea[name="message"]'
    ) as HTMLTextAreaElement;
    const emailInput = form.querySelector(
      'input[name="email"]'
    ) as HTMLInputElement;
    const orgUrlInput = form.querySelector(
      'input[name="org-url"]'
    ) as HTMLInputElement;
    const draftPanel = document.getElementById("email-draft");
    const draftSubject = document.getElementById(
      "draft-subject"
    ) as HTMLInputElement;
    const draftBody = document.getElementById(
      "draft-body"
    ) as HTMLTextAreaElement;
    const copySubjectButton = document.getElementById(
      "copy-subject"
    ) as HTMLButtonElement;
    const copyBodyButton = document.getElementById(
      "copy-body"
    ) as HTMLButtonElement;

    function getHelpTypeLabel() {
      const selectedOption = helpTypeSelect.selectedOptions[0];
      return selectedOption?.dataset.label || selectedOption?.text || "";
    }

    function buildDraft() {
      const helpType = helpTypeSelect.value;
      const helpTypeLabel = getHelpTypeLabel();
      const subject = subjectByHelpType[helpType] || "Question for Operately";
      const bodyLines = [
        `Hi Operately team,`,
        "",
        `I need help with: ${helpTypeLabel || "[select a topic]"}`,
        "",
        messageInput.value || "[write your message here]",
        "",
        "Contact details:",
        `Email: ${emailInput.value || "[your email]"}`,
        `Organization URL: ${orgUrlInput.value || "[optional]"}`,
      ];

      return {
        subject,
        body: bodyLines.join("\n"),
      };
    }

    function updateDraft() {
      const draft = buildDraft();

      draftSubject.value = draft.subject;
      draftBody.value = draft.body;

      if (helpTypeSelect.value) {
        draftPanel?.classList.remove("hidden");
      } else {
        draftPanel?.classList.add("hidden");
      }
    }

    function buildMailtoUrl() {
      const draft = buildDraft();
      return `mailto:${contactEmail}?subject=${encodeURIComponent(
        draft.subject
      )}&body=${encodeURIComponent(draft.body)}`;
    }

    function openEmailDraft() {
      window.location.href = buildMailtoUrl();
    }

    async function copyText(value: string, button: HTMLButtonElement) {
      if (navigator.clipboard) {
        await navigator.clipboard.writeText(value);
      } else {
        const textarea = document.createElement("textarea");
        textarea.value = value;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "fixed";
        textarea.style.opacity = "0";
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand("copy");
        document.body.removeChild(textarea);
      }

      const originalLabel = button.textContent;
      button.textContent = "Copied";
      window.setTimeout(() => {
        button.textContent = originalLabel;
      }, 1400);
    }

    copySubjectButton?.addEventListener("click", () => {
      copyText(draftSubject.value, copySubjectButton);
    });

    copyBodyButton?.addEventListener("click", () => {
      copyText(draftBody.value, copyBodyButton);
    });

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      updateDraft();
      if (helpTypeSelect.value) {
        openEmailDraft();
      }
    });

    form.addEventListener("input", updateDraft);
    form.addEventListener("change", updateDraft);
    updateDraft();
  }

  document.addEventListener("DOMContentLoaded", initContactForm);
</script>

<style>
  :global(body) {
    background: #fff;
  }
</style>

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={"/images/social/card-summary-large.png"}
  twitterCardType="summary_large_image"
>
  <main class="overflow-x-hidden bg-white px-4 py-12 sm:px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
        {pageTitle}
      </h1>
      <p
        class="mx-auto mt-4 max-w-[32ch] text-base leading-7 text-gray-600 sm:max-w-xl sm:text-lg sm:leading-8"
      >
        {pageDescription}
      </p>
    </div>

    <div class="mx-auto w-full max-w-xl">
      <form
        id="contact-form"
        class="mx-auto mt-8 box-border w-full rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:mt-14 sm:p-6"
      >
        <div class="grid grid-cols-1 gap-y-5">
          <div class="sm:col-span-2">
            <label
              for="help-type"
              class="block text-base font-semibold leading-6 text-gray-900"
            >
              What can we help you with?<span class="text-red-600">*</span>
              <span class="mt-1 block text-sm font-normal leading-6 text-gray-500"
                >Let us know what brought you here</span
              >
            </label>
            <div class="mt-2.5">
              <select
                id="help-type"
                name="help-type"
                class="box-border block w-full min-w-0 rounded-md border-0 bg-white py-3 pl-3 pr-10 text-base text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-blue-600"
                required
              >
                <option value="">Select an option</option>
                <option value="access" data-label="I can't access my account"
                  >I can't access my account</option
                >
                <option
                  value="pre-signup"
                  data-label="I have a question before I sign up"
                  >I have a question before I sign up</option
                >
                <option
                  value="user-question"
                  data-label="I'm a registered user and have a question"
                  >I'm a registered user and have a question</option
                >
                <option value="bug" data-label="I think something's broken"
                  >I think something's broken</option
                >
                <option value="feature" data-label="I have a feature request"
                  >I have a feature request</option
                >
                <option
                  value="ai-access"
                  data-label="I want early access to Operately AI"
                  >I want early access to Operately AI</option
                >
                <option
                  value="commercial-license"
                  data-label="I'm interested in commercial self-hosted license"
                  >I'm interested in commercial self-hosted license</option
                >
                <option value="other" data-label="Something else"
                  >Something else</option
                >
              </select>
            </div>
          </div>

          <div class="sm:col-span-2">
            <label
              for="message"
              class="block text-base font-semibold leading-6 text-gray-900"
            >
              Tell us more
              <span class="mt-1 block text-sm font-normal leading-6 text-gray-500"
                >Optional context for the email draft</span
              >
            </label>
            <div class="mt-2.5">
              <textarea
                id="message"
                name="message"
                rows="5"
                class="box-border block min-h-32 w-full min-w-0 resize-y rounded-md border-0 px-3 py-3 text-base text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-blue-600 sm:min-h-40"
                placeholder="Share the details of your question or issue..."
              ></textarea>
            </div>
          </div>

          <div class="sm:col-span-2">
            <label
              for="email"
              class="block text-base font-semibold leading-6 text-gray-900"
            >
              Your email
              <span class="mt-1 block text-sm font-normal leading-6 text-gray-500"
                >Optional, if you want it included in the draft body</span
              >
            </label>
            <div class="mt-2.5">
              <input
                type="email"
                name="email"
                id="email"
                class="box-border block w-full min-w-0 rounded-md border-0 px-3.5 py-3 text-base text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600"
                placeholder="you@company.com"
              />
            </div>
          </div>

          <div class="sm:col-span-2">
            <label
              for="org-url"
              class="block text-base font-semibold leading-6 text-gray-900"
            >
              Your organization URL
              <span class="mt-1 block text-sm font-normal leading-6 text-gray-500"
                >Help us locate your account if you're a user</span
              >
            </label>
            <div class="mt-2.5">
              <input
                type="text"
                id="org-url"
                name="org-url"
                class="box-border block w-full min-w-0 rounded-md border-0 px-3 py-3 text-base text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-blue-600"
                placeholder="https://app.operately.com/my-org-0plx"
              />
            </div>
          </div>
        </div>

        <section
          id="email-draft"
          class="hidden mt-8 border-t border-gray-200 pt-6"
          aria-live="polite"
        >
          <div>
            <label
              for="draft-subject"
              class="block text-sm font-semibold leading-6 text-gray-900"
            >
              Subject
            </label>
            <div class="relative mt-2">
              <input
                id="draft-subject"
                type="text"
                readonly
                class="box-border block w-full min-w-0 rounded-md border-0 bg-white px-3.5 py-2.5 pr-20 text-sm text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300"
              />
              <button
                id="copy-subject"
                type="button"
                class="absolute right-2 top-1/2 min-w-12 -translate-y-1/2 rounded px-2 py-1 text-center text-xs font-semibold text-gray-500 hover:bg-gray-100 hover:text-gray-900"
                aria-label="Copy subject"
              >
                Copy
              </button>
            </div>
          </div>

          <div class="mt-6">
            <label
              for="draft-body"
              class="block text-sm font-semibold leading-6 text-gray-900"
            >
              Email body
            </label>
            <div class="relative mt-2">
              <textarea
                id="draft-body"
                rows="8"
                readonly
                class="box-border block w-full min-w-0 rounded-md border-0 bg-white px-3.5 pb-2.5 pl-3.5 pr-20 pt-10 text-sm text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300"
              ></textarea>
              <button
                id="copy-body"
                type="button"
                class="absolute right-2 top-2 min-w-12 rounded px-2 py-1 text-center text-xs font-semibold text-gray-500 hover:bg-gray-100 hover:text-gray-900"
                aria-label="Copy email body"
              >
                Copy
              </button>
            </div>
          </div>
        </section>

        <div class="mt-8">
          <button
            type="submit"
            id="submit-button"
            class="w-full rounded-md bg-blue-600 px-3.5 py-3.5 text-base font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600"
          >
            Open email draft
          </button>
          <p class="mt-3 text-sm leading-6 text-gray-500">
            Opens your email app with the generated subject and body.
          </p>
        </div>
      </form>
    </div>
  </main>
</BaseLayout>
