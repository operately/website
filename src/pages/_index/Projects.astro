---
import { Image } from "astro:assets";
import Screenshot from "../_index/project.png";
import { Map, UserCheck, Users } from "lucide-react";
---

<div class="py-8 sm:py-12">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- intro -->
    <div class="mx-auto max-w-2xl text-center">
      <h2
        class="mt-2 text-pretty text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl lg:text-balance"
      >
        Project management for every department
      </h2>
      <p class="mt-6 text-lg leading-8 text-gray-600">
        Task boards, milestones, and ownership keep initiatives moving.
        Operately replaces Basecamp, Asana or Trello with a system that’s tied
        directly to company goals.
      </p>
    </div>
  </div>
  <!-- big screenshot / video prompt -->
  <div class="relative overflow-hidden pt-16">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <div
        class="relative isolate overflow-hidden bg-operately-blue px-6 pt-8 sm:mx-auto sm:max-w-5xl sm:rounded-3xl sm:pt-16 sm:px-16 lg:mx-0 lg:max-w-none"
      >
        <div
          aria-hidden="true"
          class="absolute -inset-y-px -left-3 -z-10 w-full origin-bottom-left skew-x-[-30deg] bg-operately-blue-tint-1 opacity-20 ring-1 ring-white ring-inset"
        >
        </div>
        <div
          class="mx-auto max-w-5xl sm:mx-0 sm:max-w-none flex justify-center"
        >
          <Image
            src={Screenshot}
            alt="Operately screenshot, dashboard with goals and projects."
            class="mb-[-12%] w-full max-w-none rounded-t-xl bg-gray-800 ring-1 ring-white/10"
          />
        </div>
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 ring-1 ring-black/10 ring-inset sm:rounded-3xl"
        >
        </div>
      </div>
      <div class="relative" aria-hidden="true">
        <div
          class="absolute -inset-x-20 bottom-0 bg-gradient-to-t from-white pt-[7%]"
        >
        </div>
      </div>
    </div>
  </div>
  <!-- the gist -->
  <div class="mx-auto mt-16 max-w-7xl px-6 sm:mt-12 md:mt-18 lg:px-8">
    <dl
      class="mx-auto grid max-w-2xl grid-cols-1 gap-x-6 gap-y-10 text-base leading-7 text-gray-600 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3 lg:gap-x-8 lg:gap-y-16"
    >
      <div class="relative pl-9">
        <dt class="inline font-semibold text-gray-900">
          <Map className="absolute left-1 top-1 h-5 w-5 text-operately-blue" />
          Always know who owns what.
        </dt>
        <!-- space -->
        <dd class="inline">
          Every project has a champion, a clear status, and milestones that are
          tracked automatically.
        </dd>
      </div>
      <div class="relative pl-9">
        <dt class="inline font-semibold text-gray-900">
          <UserCheck
            className="absolute left-1 top-1 h-5 w-5 text-operately-blue"
          />
          Measure progress by outcomes, not busywork.
        </dt>
        <!-- space -->
        <dd class="inline">
          Projects are measured by milestones and results, not task-level noise.
        </dd>
      </div>
      <div class="relative pl-9">
        <dt class="inline font-semibold text-gray-900">
          <Users
            className="absolute left-1 top-1 h-5 w-5 text-operately-blue"
          />
          Fast feedback loops without chasing updates.
        </dt>
        <!-- space -->
        <dd class="inline">
          Check-ins and reminders keep progress flowing. Great for building an
          async-first, remote-friendly culture.
        </dd>
      </div>
    </dl>
  </div>
</div>
