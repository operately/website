---
import BaseLayout from "../layouts/BaseLayout.astro";

import Statement from "./_open-source/Statement.astro";
import PublicChannels from "./_open-source/PublicChannels.astro";

const pageTitle = "Why Open Source?";
const pageDescription =
  "Business software needs a reset. Operately is building a product that is sustainable, open, and transparent.";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={"/images/social/card-summary-large.png"}
  twitterCardType="summary_large_image"
>
  <main class="bg-[#FAFAF8] py-8 sm:py-16">
    <Statement />
    <PublicChannels />
    <div class="mt-16 mb-8 mx-auto max-w-6xl border-t border-gray-200"></div>
  </main>
</BaseLayout>
